  "remarks": "🇪🇺 Автовыбор (b1) + Антиреклама",
  // ... (основные настройки DNS, inbounds, observatory)
  "outbounds": [
    {"tag": "direct", "protocol": "freedom"},
    {"tag": "block", "protocol": "blackhole"},
    {
      "tag": "b1-frda-fLkVmG7fik",
      "protocol": "vless",
      "settings": {
        "vnext": [{
          "address": "2.26.129.246",
          "port": 443,
          "users": [{"id": "...", "encryption": "none", "flow": "xtls-rprx-vision"}]
        }]
      },
      "streamSettings": {"network": "tcp", "security": "reality", "realitySettings": {"serverName": "ukrop.mycdn-me.ru", "publicKey": "..."}}
    }
    // ... остальные сервера b1-germany-1, b1-mt
  ],
  "routing": {
    "domainMatcher": "hybrid",
    "domainStrategy": "AsIs",
    "rules": [
      {"type": "field", "domain": ["geosite:category-ads-all"], "outboundTag": "block"},
      {"type": "field", "inboundTag": ["socks", "entry-tier3"], "network": "tcp,udp", "balancerTag": "lb_b1"}
